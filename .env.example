# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# AI API Keys
GOOGLE_AI_API_KEY=your-gemini-api-key
GROQ_API_KEY=your-groq-api-key
OPENAI_API_KEY=your-openai-api-key

# Application
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# Frontend URLs (for OAuth redirects)
# Local development
FRONTEND_URL=http://localhost:5173
FRONTEND_SUCCESS_URL=http://localhost:5173/auth/callback
FRONTEND_ERROR_URL=http://localhost:5173/login

# Production (uncomment and update when deploying)
# FRONTEND_URL=https://your-frontend-domain.com
# FRONTEND_SUCCESS_URL=https://your-frontend-domain.com/auth/callback
# FRONTEND_ERROR_URL=https://your-frontend-domain.com/login

# CORS - Allowed origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5500

# OAuth Configuration
NEXT_PUBLIC_OAUTH_REDIRECT_URL=http://localhost:3000/auth/callback

# Email Encryption
# Generate a key using: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
EMAIL_ENCRYPTION_KEY=your-256-bit-encryption-key-in-hex

# Workflow Execution Retention
# Number of days to retain execution records before automatic cleanup (default: 90)
EXECUTION_RETENTION_DAYS=90

# Enable scheduled cleanup worker (set to 'true' to enable automatic cleanup)
# When enabled, cleanup runs every 24 hours
ENABLE_SCHEDULED_CLEANUP=false

# Rate Limiting Configuration
# Email sending limit per hour per user (default: 100)
RATE_LIMIT_EMAIL_PER_HOUR=100

# Workflow execution limit per day per user (default: 1000)
RATE_LIMIT_WORKFLOW_PER_DAY=1000
